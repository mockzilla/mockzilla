{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mockzilla Service Config Schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Service name."
    },
    "history": {
      "type": "object",
      "description": "Request/response history recording configuration.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable history recording.",
          "default": true
        },
        "mask-headers": {
          "type": "array",
          "description": "Header name patterns to mask in history entries. Supports trailing wildcard (e.g., 'X-Internal-*').",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "latency": {
      "type": "string",
      "description": "Fixed latency (e.g., '100ms')."
    },
    "latencies": {
      "type": "object",
      "description": "Percentile-based latencies (e.g., p50: 10ms, p99: 100ms).",
      "additionalProperties": {
        "type": "string"
      }
    },
    "errors": {
      "type": "object",
      "description": "Percentile-based error injection (e.g., p10: 500).",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "validate": {
      "type": "object",
      "properties": {
        "request": {
          "type": "boolean",
          "description": "Validate requests.",
          "default": true
        },
        "response": {
          "type": "boolean",
          "description": "Validate responses.",
          "default": false
        }
      }
    },
    "cache": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "boolean",
          "description": "Cache GET requests.",
          "default": true
        },
        "replay": {
          "type": "object",
          "description": "Replay (VCR-like) configuration: record API responses and replay them on subsequent requests matching specific payload criteria.",
          "properties": {
            "ttl": {
              "type": "string",
              "description": "Time-to-live for recordings (e.g., '24h', '1h30m').",
              "default": "24h"
            },
            "upstream-only": {
              "type": "boolean",
              "description": "Only record responses from upstream services.",
              "default": false
            },
            "auto-replay": {
              "type": "boolean",
              "description": "Activate replay for configured endpoints without requiring the X-Mz-Replay header.",
              "default": false
            },
            "endpoints": {
              "type": "object",
              "description": "Map of path patterns to HTTP methods and their match configurations.",
              "additionalProperties": {
                "type": "object",
                "description": "HTTP methods for this path pattern.",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "match": {
                      "type": "array",
                      "description": "Dotted paths into request body to extract match values (e.g., 'data.name', 'data.address.zip').",
                      "items": {
                        "type": "string"
                      }
                    }
                  },
                  "required": ["match"]
                }
              }
            }
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "description": "OpenAPI spec simplification options.",
      "properties": {
        "simplify": {
          "type": "boolean",
          "description": "Enable spec simplification.",
          "default": false
        },
        "optional-properties": {
          "type": "object",
          "description": "Controls how many optional properties to keep. When not set, all optional properties are kept.",
          "properties": {
            "min": {
              "type": "integer",
              "description": "Minimum number of optional properties to keep."
            },
            "max": {
              "type": "integer",
              "description": "Maximum number of optional properties to keep."
            }
          }
        }
      }
    },
    "resources-prefix": {
      "type": "string",
      "description": "Prefix for helper routes outside OpenAPI spec."
    },
    "generate": {
      "type": "object",
      "description": "Code generation options.",
      "properties": {
        "server": {
          "type": "object",
          "description": "Enable server/main.go generation when present."
        }
      }
    },
    "upstream": {
      "type": "object",
      "description": "Upstream proxy configuration.",
      "properties": {
        "url": {
          "type": "string",
          "description": "Upstream URL."
        },
        "timeout": {
          "type": "string",
          "description": "Request timeout duration (e.g., '5s').",
          "default": "5s"
        },
        "headers": {
          "type": "object",
          "description": "Headers to add to upstream requests.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "fail-on": {
          "type": "array",
          "description": "HTTP status codes to return directly to the client without falling back to the generator. Default: 400-499 except 401, 403. Set to empty array to disable.",
          "items": {
            "$ref": "#/definitions/http-status-match"
          }
        },
        "sticky-timeout": {
          "type": "string",
          "description": "When a request falls back to the generator, all subsequent requests to this service skip upstream for this duration (e.g., '30s'). 0 or omitted = disabled.",
          "default": "0"
        }
      }
    }
  },
  "definitions": {
    "http-status-match": {
      "type": "object",
      "properties": {
        "exact": {
          "type": "integer",
          "description": "Exact HTTP status code."
        },
        "range": {
          "type": "string",
          "description": "HTTP status range (e.g., '500-599')."
        },
        "except": {
          "type": "array",
          "description": "Status codes to exclude from matching.",
          "items": {
            "type": "integer"
          }
        },
        "body": {
          "type": "object",
          "description": "Refine fail-on rules based on response body JSON fields.",
          "properties": {
            "default": {
              "type": "string",
              "enum": ["fail", "except"],
              "default": "fail",
              "description": "Decides the outcome when neither fail nor except conditions match, or when both match."
            },
            "fail": {
              "type": "array",
              "description": "Always fail (return error to client) when ALL conditions match.",
              "items": {
                "$ref": "#/definitions/body-match-condition"
              }
            },
            "except": {
              "type": "array",
              "description": "Never fail (fall through to generator) when ALL conditions match.",
              "items": {
                "$ref": "#/definitions/body-match-condition"
              }
            }
          }
        }
      }
    },
    "body-match-condition": {
      "type": "object",
      "description": "A condition matching a JSON field in the response body.",
      "properties": {
        "path": {
          "type": "string",
          "description": "Dot-notation path to a JSON field (e.g., 'error.detail.code')."
        },
        "equals": {
          "description": "Value to compare against. Supports string, number, or boolean."
        }
      },
      "required": ["path", "equals"]
    }
  }
}

